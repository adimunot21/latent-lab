{
  "name": "latent-lab-web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Browser playground for JEPA world models (onnxruntime-web, WebGPU + WASM).",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "vite",
    "build": "svelte-check --tsconfig ./tsconfig.app.json && vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@playwright/test": "^1.49.0",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^24.13.2",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-svelte": "^3.0.0",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^3.3.2",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.19.0",
    "vite": "^8.1.1",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "onnxruntime-web": "^1.20.1"
  }
}
