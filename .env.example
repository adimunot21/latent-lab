# Copy to `.env` (gitignored) and fill in. Never commit real secrets.

# Hugging Face Hub token — only needed to PUSH exported models/manifests.
# Create at https://huggingface.co/settings/tokens (write scope).
HF_TOKEN=

# Target HF repo for model artifacts (created in Phase 4).
HF_REPO_ID=adimunot21/latent-lab

# Optional: Weights & Biases (training uses TensorBoard by default).
# WANDB_API_KEY=
